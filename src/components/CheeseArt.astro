---
// Small line-and-fill illustrations for the cheese cards.
// One component, five variants. Colours ride the theme tokens where
// they can and use fixed rind hues where the cheese demands it.
const { kind = 'bloomy', title = '' } = Astro.props;
---
<svg viewBox="0 0 200 120" role="img" aria-label={title} focusable="false">
  {kind === 'bloomy' && (
    <g>
      <ellipse cx="100" cy="82" rx="62" ry="16" fill="#d8c9a4" opacity=".5" />
      <path d="M40 78 Q40 46 100 46 Q160 46 160 78 Q160 92 100 92 Q40 92 40 78 Z" fill="#f3ead2" stroke="#b8a87e" stroke-width="2" />
      <path d="M46 72 Q60 58 100 56 Q140 58 154 72" fill="none" stroke="#fff" stroke-width="5" opacity=".7" stroke-linecap="round" />
      <path d="M132 50 L168 38 L166 60 Q150 68 134 66 Z" fill="#f6ecc9" stroke="#b8a87e" stroke-width="1.8" />
      <path d="M136 62 Q150 60 163 55" stroke="#e8cf92" stroke-width="4" fill="none" opacity=".9" />
      <circle cx="72" cy="74" r="1.6" fill="#b8a87e" opacity=".5" />
      <circle cx="118" cy="80" r="1.4" fill="#b8a87e" opacity=".5" />
    </g>
  )}
  {kind === 'washed' && (
    <g>
      <ellipse cx="100" cy="84" rx="58" ry="15" fill="#a8683a" opacity=".28" />
      <path d="M48 78 Q48 50 100 50 Q152 50 152 78 Q152 90 100 90 Q48 90 48 78 Z" fill="#cf8a4c" stroke="#8a5227" stroke-width="2" />
      <path d="M54 70 Q72 58 100 57 Q128 58 146 70" fill="none" stroke="#e5a866" stroke-width="4" opacity=".8" stroke-linecap="round" />
      <path d="M60 82 Q100 88 140 82" fill="none" stroke="#8a5227" stroke-width="1.2" opacity=".5" />
      <path d="M78 64 q4 -3 8 0 M112 62 q4 -3 8 0" stroke="#8a5227" stroke-width="1.1" fill="none" opacity=".55" />
    </g>
  )}
  {kind === 'natural' && (
    <g>
      <ellipse cx="100" cy="92" rx="56" ry="13" fill="#6f5a3e" opacity=".3" />
      <rect x="52" y="34" width="96" height="60" rx="12" fill="#c0ab83" stroke="#6f5a3e" stroke-width="2" />
      <ellipse cx="100" cy="36" rx="48" ry="11" fill="#d3c096" stroke="#6f5a3e" stroke-width="2" />
      <path d="M58 52 h84 M58 66 h84 M58 80 h84" stroke="#6f5a3e" stroke-width="1" opacity=".35" />
      <circle cx="72" cy="59" r="1.4" fill="#5c4a32" opacity=".6" />
      <circle cx="121" cy="73" r="1.6" fill="#5c4a32" opacity=".6" />
      <circle cx="98" cy="87" r="1.3" fill="#5c4a32" opacity=".6" />
      <text x="78" y="42" font-family="'Space Mono', monospace" font-size="8" letter-spacing="1.5" fill="#5c4a32" opacity=".75">RN·214</text>
    </g>
  )}
  {kind === 'clothbound' && (
    <g>
      <ellipse cx="100" cy="94" rx="58" ry="13" fill="#6f5a3e" opacity=".3" />
      <rect x="48" y="30" width="104" height="66" rx="10" fill="#cbb997" stroke="#6f5a3e" stroke-width="2" />
      <ellipse cx="100" cy="32" rx="52" ry="11" fill="#dbcba6" stroke="#6f5a3e" stroke-width="2" />
      <path d="M48 46 q52 12 104 0 M48 62 q52 12 104 0 M48 78 q52 12 104 0" stroke="#6f5a3e" stroke-width="1.1" fill="none" opacity=".4" />
      <path d="M64 30 v64 M100 43 v53 M136 30 v64" stroke="#6f5a3e" stroke-width="1" opacity=".25" />
      <path d="M84 26 q16 -8 32 0" stroke="#6f5a3e" stroke-width="1.4" fill="none" opacity=".5" />
    </g>
  )}
  {kind === 'ashed' && (
    <g>
      <ellipse cx="100" cy="82" rx="62" ry="16" fill="#8c8676" opacity=".35" />
      <path d="M40 78 Q40 46 100 46 Q160 46 160 78 Q160 92 100 92 Q40 92 40 78 Z" fill="#e6e0d0" stroke="#7a745f" stroke-width="2" />
      <path d="M46 72 Q60 58 100 56 Q140 58 154 72" fill="none" stroke="#fff" stroke-width="4.5" opacity=".65" stroke-linecap="round" />
      <path d="M50 80 Q100 90 150 80" fill="none" stroke="#5c574a" stroke-width="2.4" opacity=".5" />
      <path d="M132 50 L168 38 L166 60 Q150 68 134 66 Z" fill="#f2ead0" stroke="#7a745f" stroke-width="1.8" />
      <path d="M134 58 L165 48" stroke="#4a463c" stroke-width="2.2" opacity=".75" />
      <circle cx="70" cy="66" r="1.4" fill="#5c574a" opacity=".55" />
      <circle cx="112" cy="76" r="1.5" fill="#5c574a" opacity=".55" />
      <circle cx="90" cy="84" r="1.2" fill="#5c574a" opacity=".45" />
    </g>
  )}
  {kind === 'tomme' && (
    <g>
      <ellipse cx="100" cy="86" rx="60" ry="14" fill="#8f7a56" opacity=".3" />
      <path d="M44 76 Q44 52 100 52 Q156 52 156 76 Q156 88 100 88 Q44 88 44 76 Z" fill="#d3c096" stroke="#8f7a56" stroke-width="2" />
      <path d="M50 68 Q74 58 100 57 Q126 58 150 68" fill="none" stroke="#bfa878" stroke-width="3" opacity=".7" />
      <path d="M62 60 l6 4 M96 56 l6 4 M130 60 l6 4" stroke="#8f7a56" stroke-width="1.1" opacity=".5" />
      <path d="M120 54 L152 44 L150 62 Q136 68 122 66 Z" fill="#efe3bc" stroke="#8f7a56" stroke-width="1.8" />
      <circle cx="137" cy="55" r="1.6" fill="#cbb371" />
    </g>
  )}
</svg>
